# Environment in which the API is running
# Development, Staging, or Production
ASPNETCORE_ENVIRONMENT=Production


# PostgreSQL connection string used by the Identity module
# In production, replace credentials and host with deployment values
ConnectionStrings__Identity=Host=localhost;Port=5432;Database=jobwize;Username=jobwize;Password=change-me


# JWT authentication configuration

# Secret key used to sign and validate JWT tokens
# IMPORTANT: Use a strong random secret and never commit the real value
Jwt__SecretKey=replace-with-a-secure-secret

# JWT token issuer identifier
Jwt__Issuer=JobWize

# JWT token audience identifier
Jwt__Audience=JobWize